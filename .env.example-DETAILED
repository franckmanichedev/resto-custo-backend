# =====================================================
# BACKEND - CONFIGURATION FIREBASE (VALUES DE SAMPLE)
# =====================================================

# Firebase Admin SDK Configuration
# Obtenez ces valeurs à partir de:
# 1. Firebase Console → Paramètres du projet → Comptes de service
# 2. Cliquez "Générer une nouvelle clé privée" → JSON

# Exemple de structure (REMPLACEZ PAR VOS VRAIES VALEURS):
FIREBASE_PROJECT_ID=resto-qrcode-test-123
FIREBASE_PRIVATE_KEY_ID=abc123def456ghi789jkl012
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQDlJ4v5...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-abc123@resto-qrcode-test-123.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789012345678901
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-abc123%40resto-qrcode-test-123.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# =====================================================
# SERVER CONFIGURATION
# =====================================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Frontend URL for CORS
# Important: Doit correspondre à l'URL où le frontend s'exécute
FRONTEND_URL=http://localhost:3000

# =====================================================
# NOTES IMPORTANTES
# =====================================================

# 1. PRIVATE_KEY
#    - Contient des caractères spéciaux
#    - Les \n doivent être littéraux (pasdes vraies nouvelles lignes)
#    - Copiez directement du JSON Firebase
#
# 2. FRONTEND_URL
#    - Sur localhost: http://localhost:3000
#    - En production: https://votre-domaine.com
#
# 3. CREDENTIALS DE FIREBASE
#    - Jamais commit ce fichier sur Git
#    - Utilisez .gitignore: echo ".env" >> .gitignore
#    - En production, utilisez des variables d'environnement système
#
# 4. LOG_LEVEL
#    - debug = très verbeux
#    - info = normal (par défaut)
#    - warn = seulement les avertissements
#    - error = seulement les erreurs

# =====================================================
# COMMENT OBTENIR LES CREDENTIALS FIREBASE
# =====================================================

# 1. Allez à https://console.firebase.google.com
# 2. Créez un nouveau projet (ou sélectionnez un existant)
# 3. Allez à Paramètres → Comptes de service
# 4. Cliquez "Générer une nouvelle clé privée"
# 5. Un fichier JSON sera téléchargé
# 6. Copiez les valeurs dans ce fichier .env
#
# Exemple du JSON téléchargé:
# {
#   "type": "service_account",
#   "project_id": "resto-qrcode-test-123",
#   "private_key_id": "abc123def456...",
#   "private_key": "-----BEGIN PRIVATE KEY-----\n...",
#   ...
# }

# =====================================================
# SÉCURITÉ - CHECKLIST
# =====================================================

# ✓ .env n'est JAMAIS commit (vérifiez .gitignore)
# ✓ PRIVATE_KEY est sécurisée (pas en logs)
# ✓ FRONTEND_URL correspond au vrai domaine frontend
# ✓ NODE_ENV=production en prod
# ✓ PORT accessible (5000 par défaut OK pour dev)
