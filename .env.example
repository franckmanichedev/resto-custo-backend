NODE_ENV=development
PORT=5000
LOG_LEVEL=info

FRONTEND_URL=http://localhost:5173
FRONTEND_URL_DEVELOPMENT=http://localhost:5173
FRONTEND_URL_PRODUCTION=https://app.example.com
BACKEND_URL_DEVELOPMENT=http://localhost:5000/api
BACKEND_URL_PRODUCTION=https://api.example.com/api

JWT_SECRET=replace-with-a-long-random-secret
SESSION_EXPIRY=86400

# Firebase Web API key used only for backend-mediated password verification.
FIREBASE_API_KEY=replace-with-firebase-web-api-key

# Firebase Admin SDK.
FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_PRIVATE_KEY_ID=replace-with-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=replace-with-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40example.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com
FIREBASE_STORAGE_BUCKET=replace-with-storage-bucket

# SaaS auth security.
PLATFORM_BOOTSTRAP_SECRET=replace-with-one-time-bootstrap-secret
AUTH_TOKEN_PEPPER=replace-with-hmac-token-pepper
DISABLE_AUTH_RATE_LIMIT=false

# Email delivery is now handled by Firebase Authentication native flows.
# Firebase Auth generates email verification and password reset links.

# Frontend Firebase Client SDK.
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-auth-domain
VITE_FIREBASE_PROJECT_ID=replace-with-project-id
VITE_FIREBASE_STORAGE_BUCKET=replace-with-storage-bucket
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_WEB_APP_ID=
